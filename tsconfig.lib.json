{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./dist",
		"types": ["node", "vite/client"]
	},
	"exclude": [
		"jest.config.ts",
		"src/**/*.spec.ts",
		"src/**/*.test.ts",
		"src/**/*.spec.tsx",
		"src/**/*.test.tsx",
		"src/**/*.spec.js",
		"src/**/*.test.js",
		"src/**/*.spec.jsx",
		"src/**/*.test.jsx",
		"**/*.stories.ts",
		"**/*.stories.js",
		"**/*.stories.jsx",
		"**/*.stories.tsx",
		"vite.config.ts",
		"vite.config.mts",
		"vitest.config.ts",
		"vitest.config.mts"
	],
	"include": ["src/**/*.js", "src/**/*.jsx", "src/**/*.ts", "src/**/*.tsx", "schema/**/*.ts"]
}
